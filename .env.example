# ===== cc-web 配置文件 =====
# 复制此文件为 .env 后修改: cp .env.example .env

# ----- 中继服务 (packages/relay) -----
# 中继 HTTP/WS 监听端口
RELAY_PORT=3001
# 本地服务注册认证 token（中继与本地需一致）
RELAY_TOKEN=dev-token
# 前端静态文件目录（相对 relay 包的路径）
STATIC_DIR=../../frontend/dist

# ----- 本地服务 (packages/local) -----
# 中转服务 WebSocket 地址
RELAY_URL=ws://localhost:3001/ws/local
# 节点标识（留空则自动使用本机 hostname）
NODE_ID=
# 节点登录密码（留空则不启用密码认证）
NODE_PASSWORD=
# WebSocket 重连初始延迟（毫秒）
RECONNECT_DELAY=2000
# WebSocket 重连最大延迟（毫秒）
MAX_RECONNECT_DELAY=30000
